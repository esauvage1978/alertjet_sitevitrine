---
import PageLayout from '../layouts/PageLayout.astro';
import ContactForm from '../components/ContactForm.astro';

const title = 'Contact';
const description =
  'Contacter l’équipe AlertJet — questions sur la gestion des incidents, tarifs ou partenariats.';
---

<PageLayout title={title} description={description}>
  <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Contact</h1>
  <p class="mt-4 max-w-2xl leading-relaxed text-slate-400">
    Une question sur AlertJet, les tarifs ou une démo ? Envoyez-nous un message. Nous vous répondons
    dans les meilleurs délais.
  </p>
  <p class="mt-3 text-sm text-slate-500">
    Application :{' '}
    <a href="https://alertjet.builders/" class="text-cyan-400 hover:underline">alertjet.builders</a>
  </p>
  <div class="mt-10">
    <ContactForm />
  </div>
</PageLayout>
