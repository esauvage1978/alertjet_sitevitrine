---
import { CONTACT_FORM_WEBHOOK } from '../config/site';
---

<div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6 sm:p-8">
  <p id="contact-status" class="hidden rounded-lg border px-4 py-3 text-sm" role="status"></p>
  <form id="contact-form" class="mt-0 space-y-5" novalidate>
    <div>
      <label for="name" class="mb-1.5 block text-sm font-medium text-slate-200"
        >Nom <span class="text-red-400">*</span></label
      >
      <input
        type="text"
        id="name"
        name="name"
        required
        autocomplete="name"
        class="w-full rounded-lg border border-slate-700 bg-slate-950 px-4 py-2.5 text-slate-100 placeholder:text-slate-600 focus:border-cyan-500 focus:outline-none focus:ring-1 focus:ring-cyan-500"
        placeholder="Votre nom"
      />
    </div>
    <div>
      <label for="company" class="mb-1.5 block text-sm font-medium text-slate-200">Société</label>
      <input
        type="text"
        id="company"
        name="company"
        autocomplete="organization"
        class="w-full rounded-lg border border-slate-700 bg-slate-950 px-4 py-2.5 text-slate-100 placeholder:text-slate-600 focus:border-cyan-500 focus:outline-none focus:ring-1 focus:ring-cyan-500"
        placeholder="Optionnel"
      />
    </div>
    <div>
      <label for="email" class="mb-1.5 block text-sm font-medium text-slate-200"
        >E-mail <span class="text-red-400">*</span></label
      >
      <input
        type="email"
        id="email"
        name="email"
        required
        autocomplete="email"
        class="w-full rounded-lg border border-slate-700 bg-slate-950 px-4 py-2.5 text-slate-100 placeholder:text-slate-600 focus:border-cyan-500 focus:outline-none focus:ring-1 focus:ring-cyan-500"
        placeholder="vous@exemple.fr"
      />
    </div>
    <div>
      <label for="objet" class="mb-1.5 block text-sm font-medium text-slate-200"
        >Objet <span class="text-red-400">*</span></label
      >
      <select
        id="objet"
        name="objet"
        required
        class="w-full rounded-lg border border-slate-700 bg-slate-950 px-4 py-2.5 text-slate-100 focus:border-cyan-500 focus:outline-none focus:ring-1 focus:ring-cyan-500"
      >
        <option value="" disabled selected>Choisir un sujet</option>
        <option value="general">Demande générale</option>
        <option value="demo">Demander une démo</option>
        <option value="tarifs">Tarifs / abonnement</option>
        <option value="partenariat">Partenariat</option>
        <option value="technique">Support technique</option>
        <option value="autre">Autre</option>
      </select>
    </div>
    <div>
      <label for="message" class="mb-1.5 block text-sm font-medium text-slate-200"
        >Message <span class="text-red-400">*</span></label
      >
      <textarea
        id="message"
        name="message"
        required
        rows="5"
        class="w-full resize-y rounded-lg border border-slate-700 bg-slate-950 px-4 py-2.5 text-slate-100 placeholder:text-slate-600 focus:border-cyan-500 focus:outline-none focus:ring-1 focus:ring-cyan-500"
        placeholder="Votre message…"></textarea>
    </div>
    <div class="flex items-start gap-3">
      <input
        type="checkbox"
        id="privacy"
        name="privacy"
        required
        class="mt-1 h-4 w-4 rounded border-slate-600 bg-slate-950 text-cyan-500 focus:ring-cyan-500"
      />
      <label for="privacy" class="text-sm text-slate-400 leading-relaxed">
        J’ai lu et j’accepte la{' '}
        <a href="/politique-de-confidentialite" class="font-medium text-cyan-400 hover:underline"
          >politique de confidentialité</a
        >. <span class="text-red-400">*</span>
      </label>
    </div>
    <button
      type="submit"
      id="contact-submit"
      class="w-full rounded-xl bg-cyan-500 px-6 py-3.5 text-base font-semibold text-slate-950 shadow-lg shadow-cyan-500/25 transition hover:bg-cyan-400 disabled:cursor-not-allowed disabled:opacity-60 sm:w-auto"
    >
      Envoyer
    </button>
  </form>
  <noscript>
    <p class="mt-4 text-sm text-slate-500">
      Activez JavaScript pour envoyer le formulaire, ou écrivez-nous depuis votre messagerie.
    </p>
  </noscript>
</div>

<script define:vars={{ CONTACT_FORM_WEBHOOK }}>
  const form = document.getElementById('contact-form');
  const statusEl = document.getElementById('contact-status');
  const submitBtn = document.getElementById('contact-submit');

  function showStatus(kind, text) {
    if (!statusEl) return;
    statusEl.textContent = text;
    statusEl.classList.remove('hidden', 'border-green-500/50', 'bg-green-500/10', 'text-green-200', 'border-red-500/50', 'bg-red-500/10', 'text-red-200', 'border-amber-500/50', 'bg-amber-500/10', 'text-amber-100');
    if (kind === 'ok') {
      statusEl.classList.add('border-green-500/50', 'bg-green-500/10', 'text-green-200');
    } else if (kind === 'err') {
      statusEl.classList.add('border-red-500/50', 'bg-red-500/10', 'text-red-200');
    } else {
      statusEl.classList.add('border-amber-500/50', 'bg-amber-500/10', 'text-amber-100');
    }
    statusEl.classList.remove('hidden');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn) return;

    const name = (document.getElementById('name'))?.value?.trim() ?? '';
    const company = (document.getElementById('company'))?.value?.trim() ?? '';
    const email = (document.getElementById('email'))?.value?.trim() ?? '';
    const objet = (document.getElementById('objet'))?.value ?? '';
    const message = (document.getElementById('message'))?.value?.trim() ?? '';
    const privacy = (document.getElementById('privacy'))?.checked;

    if (!privacy) {
      showStatus('err', 'Veuillez accepter la politique de confidentialité.');
      return;
    }

    submitBtn.disabled = true;
    showStatus('wait', 'Envoi en cours…');
    if (statusEl) {
      statusEl.classList.remove('border-green-500/50', 'bg-green-500/10', 'text-green-200', 'border-red-500/50', 'bg-red-500/10', 'text-red-200');
      statusEl.classList.add('border-slate-600', 'bg-slate-800/50', 'text-slate-300');
    }

    const payload = { name, company, email, objet, message };

    try {
      const res = await fetch(CONTACT_FORM_WEBHOOK, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Accept: 'application/json'
        },
        body: JSON.stringify(payload)
      });

      if (!res.ok) {
        const t = await res.text().catch(() => '');
        throw new Error(t || `HTTP ${res.status}`);
      }

      showStatus('ok', 'Message envoyé. Merci ! Nous vous répondrons dès que possible.');
      form.reset();
    } catch (err) {
      showStatus(
        'err',
        'Envoi impossible pour le moment (réseau ou configuration). Réessayez plus tard ou contactez-nous par e-mail.'
      );
      console.error(err);
    } finally {
      submitBtn.disabled = false;
    }
  });
</script>
